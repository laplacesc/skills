                "type": "record",
                "name": "botnet_common",
                "fields": [
                  {
                    "name": "match_type",
                    "type": "int",
                    "doc": "威胁类型，字段范围：1：Botnet C&C IP 2、3:Botnet C&C domain 4: Botnet C&C IP/port 5: Botnet C&C url 6: DNS Tunneling Communication 7 Botnet C&C Sinkhole 8 dga_detect"
                  },
                  {
                    "name": "botnet_tag",
                    "type": "string",
                    "doc": "恶意家族标签，字段长度：1-256"
                  },
