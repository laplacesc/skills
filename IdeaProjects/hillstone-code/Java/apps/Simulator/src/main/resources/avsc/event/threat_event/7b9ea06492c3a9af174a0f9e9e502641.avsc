{
  "type": "record",
  "name": "threat",
  "namespace": "com.hillstone.simulator.entity.avro.model.event.threat_event",
  "doc": "威胁日志schema，定义日期2023/5/26, 增加攻击者 受害者字段",
  "fields": [
    {
      "name": "common",
      "type": {
        "type": "record",
        "name": "common",
        "fields": [
          {
            "name": "app_name",
            "type": "string",
            "doc": "应用名称,字段长度：1-32"
          },
          {
            "name": "protocol",
            "type": "int",
            "doc": "协议,字段范围：1-65535"
          },
          {
            "name": "policy_id",
            "type": "int",
            "doc": "策略id,字段范围：1-100000"
          },
          {
            "name": "threat_profile",
            "type": "string",
            "doc": "威胁检测模板：1-16"
          },
          {
            "name": "pcap_id",
            "type": "long",
            "doc": "报文id"
          },
          {
            "name": "knowledge_id",
            "type": "int",
            "doc": "知识库id"
          },
          {
            "name": "defender_id",
            "type": "int",
            "doc": "引擎id，数据范围：1-16"
          },
          {
            "name": "event_info",
            "type": {
              "type": "record",
              "name": "event_info",
              "fields": [
                {
                  "name": "event_name",
                  "type": "string",
                  "doc": "威胁时间名称,字段长度：1-96"
                },
                {
                  "type": {
                    "items": "string",
                    "name": "tactic_id",
                    "type": "array",
                    "doc": "attck&id的战术id,字段长度：1-256"
                  },
                  "name": "tactic_info"
                },
                {
                  "type": {
                    "items": "string",
                    "name": "technique_id",
                    "type": "array",
                    "doc": "attck&id的技术id,字段长度：1-256"
                  },
                  "name": "technique_info"
                },
                {
                  "name": "begin_time",
                  "type": "long",
                  "doc": "威胁开始时间"
                },
                {
                  "name": "end_time",
                  "type": "long",
                  "doc": "威胁结束时间"
                },
                {
                  "name": "pri_type",
                  "type": "int",
                  "doc": "威胁一级类型,数据范围：1-6"
                },
                {
                  "name": "sec_type",
                  "type": "int",
                  "doc": "威胁二级类型,数据范围：1-38"
                },
                {
                  "name": "severity",
                  "type": "int",
                  "doc": "威胁等级,数据范围：1-4"
                },
                {
                  "name": "confidence",
                  "type": "int",
                  "doc": "威胁置信度,数据范围：1-100"
                },
                {
                  "name": "attacksource",
                  "type": "string",
                  "doc": "威胁来源,字段长度：1-128"
                },
                {
                  "name": "attack_result",
                  "type": "int",
                  "doc": "攻击结果,数据范围：0 未知,1 企图, 2 成功, 3失陷.默认为 0"
                },
                {
                  "name": "attack_num",
                  "type": "int",
                  "doc": "攻击次数，和威胁聚合相关"
                },
                {
                  "name": "action",
                  "type": "int",
                  "doc": "处理动作,数据范围：0 无动作, 1 仅记录日志, 2 reset, 3 填充magic 4 警告 5 阻断 6 丢弃7 告警 8 sinkhole替换 9 返回页面的http cookie 10 返回页面url参数 11 返回含有点击按钮页面，用户点击后设置cookie用于登录12 返回含有验证码页面，用户填写正确后设置cookie"
                },
                {
                  "name": "attacker",
                  "type": [
                    "null",
                    {
                      "type": "record",
                      "name": "ip_record",
                      "fields": [
                        {
                          "name": "ip_addr",
                          "type": "string",
                          "doc": "ip地址信息,字段长度：1-128"
                        },
                        {
                          "name": "ip_family",
                          "type": "int",
                          "doc": "ip 类型 1 ipv4，2ipv6"
                        }
                      ]
                    }
                  ],
                  "doc": "攻击者",
                  "default": null
                },
                {
                  "name": "victim",
                  "type": [
                    "null",
                    "ip_record"
                  ],
                  "doc": "受害者",
                  "default": null
                }
              ]
            }
          },
          {
            "name": "source_info",
            "type": {
              "type": "record",
              "name": "source_info",
              "fields": [
                {
                  "name": "addr",
                  "type": "ip_record",
                  "doc": "ip地址信息,ip"
                },
                {
                  "name": "port",
                  "type": "int",
                  "doc": "端口信息,数据范围：1-65535"
                },
                {
                  "name": "ip_mask_len",
                  "type": "int",
                  "doc": "ip掩码长度,数据范围：1-128"
                },
                {
                  "name": "nat_ip",
                  "type": "ip_record",
                  "doc": "nat ip地址"
                },
                {
                  "name": "nat_port",
                  "type": "int",
                  "doc": "nat 端口,数据范围：1-65535"
                },
                {
                  "name": "vsysid",
                  "type": "int",
                  "doc": "虚拟操作系统id,数据范围：1-1000"
                },
                {
                  "name": "interfaceid",
                  "type": "int",
                  "doc": "接口id,数据范围：1-10000"
                },
                {
                  "name": "vrid",
                  "type": "int",
                  "doc": "虚拟路由id,数据范围：1-502"
                },
                {
                  "name": "zoneid",
                  "type": "int",
                  "doc": "安全域id,数据范围：1-2050"
                },
                {
                  "name": "vsysname",
                  "type": "string",
                  "doc": "虚拟操作系统名称,字段长度：1-16"
                },
                {
                  "name": "vrname",
                  "type": "string",
                  "doc": "虚拟路由名称,字段长度：1-16"
                },
                {
                  "name": "interfacename",
                  "type": "string",
                  "doc": "接口名称,字段长度：1-16"
                },
                {
                  "name": "zonename",
                  "type": "string",
                  "doc": "安全域名称,字段长度：1-16"
                },
                {
                  "name": "auth_user",
                  "type": "string",
                  "doc": "主机信息 AAA:用户@主机"
                }
              ]
            }
          },
          {
            "name": "dst_info",
            "type": {
              "type": "record",
              "name": "dst_info",
              "fields": [
                {
                  "name": "addr",
                  "type": "ip_record",
                  "doc": "ip地址信息,同源ip"
                },
                {
                  "name": "port",
                  "type": "int",
                  "doc": "端口信息,数据范围：1-65535"
                },
                {
                  "name": "ip_mask_len",
                  "type": "int",
                  "doc": "ip掩码长度,数据范围：1-128"
                },
                {
                  "name": "nat_ip",
                  "type": "ip_record",
                  "doc": "nat ip地址"
                },
                {
                  "name": "nat_port",
                  "type": "int",
                  "doc": "nat 端口,数据范围：1-65535"
                },
                {
                  "name": "vsysid",
                  "type": "int",
                  "doc": "虚拟操作系统id,数据范围：1-1000"
                },
                {
                  "name": "interfaceid",
                  "type": "int",
                  "doc": "接口id,数据范围：1-10000"
                },
                {
                  "name": "vrid",
                  "type": "int",
                  "doc": "虚拟路由id,数据范围：1-502"
                },
                {
                  "name": "zoneid",
                  "type": "int",
                  "doc": "安全域id,数据范围：1-2050"
                },
                {
                  "name": "vsysname",
                  "type": "string",
                  "doc": "虚拟操作系统名称,字段长度：1-16"
                },
                {
                  "name": "vrname",
                  "type": "string",
                  "doc": "虚拟路由名称,字段长度：1-16"
                },
                {
                  "name": "interfacename",
                  "type": "string",
                  "doc": "接口名称,字段长度：1-16"
                },
                {
                  "name": "zonename",
                  "type": "string",
                  "doc": "安全域名称,字段长度：1-16"
                },
                {
                  "name": "auth_user",
                  "type": "string",
                  "doc": "主机信息 AAA:用户@主机"
                }
              ]
            }
          }
        ]
      },
      "doc": "公共字段，非必要不修改"
    },
    {
      "name": "engine_priv",
      "type": [
        "null",
        {
          "name": "ips",
          "type": "record",
          "fields": [
            {
              "name": "common",
              "type": {
                "type": "record",
                "name": "ips_common",
                "fields": [
                  {
                    "name": "attack_content",
                    "type": "string",
                    "doc": "攻击内容，字段长度：1-5600，base64编码上送"
                  },
                  {
                    "name": "attack_pos",
                    "type": "string",
                    "doc": "攻击匹配段，例如[[1,4],[2,8],[9,10]]，每个数组代表一个高亮匹配段"
                  },
                  {
                    "name": "ips_type",
                    "type": "int",
                    "doc": "私有字段类型,和下面私有字段相关。1 engine_detect 2 protocol_abnormal 3 inject_attack 4 hidden_iframe 5 extern_link 6 web_acl 7 cc_defense 8 cc_limit 9  cc_url_limit  10 brute_force 11 weak_password 12 sus_ua 13 sensitive_file"
                  },
                  {
                    "name": "CVE_ID",
                    "type": "string",
                    "doc": "CVE_ID，字段长度：1-96"
                  }
                ]
              }
            },
            {
              "name": "priv",
              "type": [
                "null",
                {
                  "name": "engine_detect",
                  "type": "record",
                  "fields": [
                    {
                      "name": "block_type",
                      "type": "int",
                      "doc": "阻断类型。1 block_ip 2 block_service"
