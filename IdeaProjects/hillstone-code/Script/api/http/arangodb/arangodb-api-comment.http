### LookUp
# LOOKUP ON Person WHERE Person.firstName == "{1}" YIELD Person.firstName, Person.lastName, Person.gender, Person.birthday, Person.creationDate, Person.locationIP, Person.browserUsed
POST http://10.182.63.120:8529/_db/ldbc/_api/cursor
Content-Type: application/json

{
  "query": "FOR vertex IN comment FILTER vertex.content == @content RETURN { 'content': vertex.content, 'length': vertex.length, 'creationDate': vertex.creationDate, 'locationIP': vertex.locationIP, 'browserUsed': vertex.browserUsed }",
  "bindVars": {
    "content": "duh"
  },
  "count": false,
  "batchSize": 1
}

