### FetchEdge
# FETCH PROP ON KNOWS {0} -> {1} YIELD KNOWS.creationDate
POST http://10.182.63.120:8529/_db/ldbc/_api/cursor
Content-Type: application/json

{
  "query": "FOR edge IN comment_replyOf_comment FILTER edge._from == @comment1 AND edge._to == @comment2 RETURN edge['Comment.id1']",
  "bindVars": {
    "comment1": "comment/8246337208332",
    "comment2": "comment/8246337208329"
  },
  "count": false,
  "batchSize": 1
}

### FetchTag
# FETCH PROP ON Person {0} YIELD Person.firstName, Person.lastName, Person.gender, Person.birthday, Person.creationDate, Person.locationIP, Person.browserUsed
POST http://10.182.63.120:8529/_db/ldbc/_api/cursor
Content-Type: application/json

{
  "query": "FOR vertex IN person FILTER vertex._key == @person RETURN { 'firstName': vertex.firstName, 'lastName': vertex.lastName, 'gender': vertex.gender, 'birthday': vertex.birthday, 'creationDate': vertex.creationDate, 'locationIP': vertex.locationIP, 'browserUsed': vertex.browserUsed }",
  "bindVars": {
    "person": "933"
  },
  "count": false,
  "batchSize": 1
}

### Go1StepDst
# GO 1 STEP FROM {0} OVER KNOWS yield $$.Person.firstName
POST http://10.182.63.120:8529/_db/ldbc/_api/cursor
Content-Type: application/json

{
  "query": "FOR edge IN person_knows_person FILTER edge._from == @person FOR vertex IN person FILTER vertex._id == edge._to RETURN vertex.firstName",
  "bindVars": {
    "person": "person/933"
  },
  "count": false,
  "batchSize": 1
}

### Go1StepEdge
# GO 1 STEP FROM {0} OVER KNOWS yield KNOWS.creationDate
